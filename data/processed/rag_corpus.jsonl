{"chunk_id": "doc_muscovite#chunk_002", "doc_id": "doc_muscovite", "license": "source_metadata_only", "mineral": "muscovite", "page": null, "source": "Britannica Muscovite", "text": "片状解理可以辅助识别白云母，但可信回答仍需要证据来源。", "topic": "mineral_property", "url": "https://www.britannica.com/science/muscovite-mineral"}
{"chunk_id": "doc_kaolinite#chunk_001", "doc_id": "doc_kaolinite", "license": "source_metadata_only", "mineral": "kaolinite", "page": null, "source": "PubChem Kaolinite", "text": "高岭石是黏土矿物，属于层状硅酸盐体系。", "topic": "concept", "url": "https://pubchem.ncbi.nlm.nih.gov/compound/71300855"}
