{"chunk_id": "doc_gypsum#chunk_002", "doc_id": "doc_gypsum", "license": "source_metadata_only", "mineral": "gypsum", "page": null, "source": "Minerals Education Coalition Gypsum", "text": "石膏硬度较低，不能仅凭浅色外观与方解石或石英区分。", "topic": "mineral_property", "url": "https://mineralseducationcoalition.org/minerals-database/gypsum/"}
{"chunk_id": "doc_magnetite#chunk_001", "doc_id": "doc_magnetite", "license": "source_metadata_only", "mineral": "magnetite", "page": null, "source": "PubChem Iron oxide Fe3O4", "text": "磁铁矿是铁氧化物矿物，常用化学式为 Fe3O4。", "topic": "concept", "url": "https://pubchem.ncbi.nlm.nih.gov/compound/Iron-oxide-_Fe3O4"}
{"chunk_id": "doc_magnetite#chunk_002", "doc_id": "doc_magnetite", "license": "source_metadata_only", "mineral": "magnetite", "page": null, "source": "Britannica Magnetite", "text": "磁性可以辅助区分磁铁矿和赤铁矿，但最终结论仍应结合结构或光谱证据。", "topic": "mineral_property", "url": "https://www.britannica.com/science/magnetite"}
{"chunk_id": "doc_pyrite#chunk_001", "doc_id": "doc_pyrite", "license": "source_metadata_only", "mineral": "pyrite", "page": null, "source": "PubChem Pyrite", "text": "黄铁矿是硫化物矿物，常用化学式为 FeS2。", "topic": "concept", "url": "https://pubchem.ncbi.nlm.nih.gov/compound/Pyrite"}
