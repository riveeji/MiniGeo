{"chunk_id": "doc_olivine#chunk_002", "doc_id": "doc_olivine", "license": "public_use_permitted", "mineral": "olivine", "page": null, "source": "NASA NTRS feldspar Raman characterization", "text": "橄榄石与辉石都可出现在镁铁质岩石中，分类时需要结合晶体结构和谱学证据。", "topic": "mineral_property", "url": "https://ntrs.nasa.gov/citations/20030111413"}
