{"chunk_id": "doc_anorthite#chunk_001", "doc_id": "doc_anorthite", "license": "source_metadata_only", "mineral": "anorthite", "page": null, "source": "PubChem Anorthite", "text": "钙长石是斜长石端元之一，化学组成可表示为 CaAl2Si2O8。", "topic": "concept", "url": "https://pubchem.ncbi.nlm.nih.gov/compound/Anorthite"}
